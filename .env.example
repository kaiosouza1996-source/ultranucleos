# URL do engine no Railway (ex: https://ultranucleos-engine.up.railway.app)
# IMPORTANTE: use sempre https:// em produção — o painel roda em HTTPS no Railway
# e uma URL http:// aqui causa bloqueio por mixed content no navegador.
# Deixe vazio para usar localhost:8787 em desenvolvimento
VITE_ENGINE_URL=

# Em produção, defina como "true" para desativar completamente o modo simulação
# (nunca fabricar QR/conexão falsos quando o Sistema local estiver offline).
# Deixe vazio/false em desenvolvimento para poder navegar na UI sem o engine rodando.
VITE_DISABLE_MOCK=

# Mesma chave configurada como ENGINE_API_KEY no whatsapp-engine (item 2 de
# segurança). Obrigatória — sem ela toda chamada ao engine retorna 401.
VITE_ENGINE_API_KEY=

# Login com papéis (Sócio/Comercial/Operacional) e Comunicação Interna agora
# rodam dentro do próprio whatsapp-engine (auth.js/comms.js), sem depender de
# nenhum serviço terceiro — não há variável nova aqui, tudo usa VITE_ENGINE_URL
# acima. (Antes: VITE_SUPABASE_URL/VITE_SUPABASE_ANON_KEY, removidas.)

