# Porta do servidor (Railway define automaticamente via PORT)
PORT=8787

# Diretório para dados persistentes (.wwebjs_auth, data.db, media/).
# Em produção (VPS/Railway), aponte para um volume/disco persistente, ex: /data
DATA_DIR=

# Caminho do Chromium instalado via apt (ver Dockerfile). Deixe vazio em
# desenvolvimento local para usar o Chromium baixado pelo próprio Puppeteer.
PUPPETEER_EXECUTABLE_PATH=

# ── Segurança (obrigatórias — o servidor recusa subir sem elas) ──────────

# Chave da API do engine — mesma usada como VITE_ENGINE_API_KEY no frontend.
# Gere com: openssl rand -hex 32
ENGINE_API_KEY=

# Chave própria de POST /public/leads (captação de landing page externa) —
# nunca a mesma do ENGINE_API_KEY acima. Sem esta variável, o endpoint
# responde 503. Gere com: openssl rand -hex 32
PUBLIC_LEADS_API_KEY=

# Chave AES-256 (32 bytes em base64) para criptografar documento/telefone.
# Gere com: openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# Segredo para o hash determinístico (HMAC-SHA256) do telefone — usado só
# para casar mensagens recebidas com o contato certo, nunca exibido.
# Gere com: openssl rand -hex 32
PHONE_HASH_SECRET=

# ── Postgres self-hosted (substitui Supabase por completo) ──────────────
# Sem DATABASE_URL, o resto do engine (CRM/WhatsApp em SQLite) funciona
# normalmente; só login, Comunicação Interna e rotas restritas a Sócio
# responderão 503/401 até configurar.
# Local (docker compose): postgres://ultranucleos:SENHA@localhost:5432/ultranucleos
DATABASE_URL=

# Origem exata do frontend (ex: https://crm.aureainvesting.com.br, ou
# http://localhost:8080 em dev) — obrigatória para o cookie de sessão
# funcionar entre frontend e engine (CORS com credentials:true exige
# origem explícita, nunca "*"). Sem ela, login por cookie não funciona,
# mas o resto do sistema (API key) continua normal.
FRONTEND_ORIGIN=

# ── Sessão (login próprio) ───────────────────────────────────────────────
# false só em dev local sem HTTPS — em produção deixe sempre true.
SESSION_COOKIE_SECURE=true
SESSION_TTL_HOURS=12

# Bloqueio progressivo por conta (além do rate limit por IP já existente).
LOGIN_RATE_LIMIT_MAX=5
LOGIN_LOCKOUT_MINUTES=15

# Expiração do token de recuperação de senha / criação de conta.
PASSWORD_RESET_TOKEN_TTL_MIN=30

# URL pública do frontend — usada para montar o link de "redefinir senha"
# enviado por e-mail (ex: https://crm.aureainvesting.com.br).
APP_BASE_URL=

# ── SMTP próprio (recuperação de senha) ──────────────────────────────────
# Sem essas variáveis, o link de reset é gerado mas o e-mail não é enviado
# (fica disponível só via log/rota administrativa).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ultra Nucleos <no-reply@seudominio.com.br>"

# Deixe em false (ou remova) em produção — só existe para ambientes locais
# onde antivírus/firewall corporativo faz inspeção de TLS e substitui o
# certificado do servidor SMTP por um autoassinado, que seria rejeitado.
SMTP_ALLOW_SELF_SIGNED=false

# ── Descontinuado (mantido só para referência durante a transição) ──────
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=
